@page "/login"
@inject NavigationManager Navigation
@attribute [StreamRendering]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using MTGProject.Services
@inject AuthService AuthService

<h3>Login</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="validation-message">@errorMessage</p>
}

<EditForm Model="loginModel" OnValidSubmit="LoginUser">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label for="email">Email</label>
        <input id="email" @bind="loginModel.Email" />
        <ValidationMessage For="@(() => loginModel.Email)" />
    </div>

    <div>
        <label for="password">Password</label>
        <input id="password" type="password" @bind="loginModel.Password" />
        <ValidationMessage For="@(() => loginModel.Password)" />
    </div>

    <button type="submit" disabled="@isLoading">Login</button>
</EditForm>

@if (isLoading)
{
    <p>Loading...........</p>
    <div class="spinner"></div>
}


<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f4f6f8;
        margin: 0;
        padding: 0;
    }

    h3 {
        text-align: center;
        margin-top: 2rem;
        font-size: 2rem;
        color: #333;
    }

    form {
        max-width: 400px;
        margin: 2rem auto;
        padding: 2rem;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: #444;
    }

    input {
        width: 100%;
        padding: 0.6rem;
        margin-bottom: 1rem;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 1rem;
        transition: border 0.2s ease;
    }

    input:focus {
        border-color: #007bff;
        outline: none;
    }

    button {
        width: 100%;
        padding: 0.75rem;
        font-size: 1rem;
        background-color: #007bff;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    button:disabled {
        background-color: #7aa7dd;
        cursor: not-allowed;
    }

    button:hover:not(:disabled) {
        background-color: #0056b3;
    }

    .validation-message {
        color: red;
        font-size: 0.85rem;
        margin-top: -0.5rem;
        margin-bottom: 0.75rem;
    }

    .spinner {
        margin: 1rem auto;
        border: 5px solid #f3f3f3;
        border-top: 5px solid #007bff;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }
    
    p {
        text-align: center;
        font-size: 1rem;
        color: #555;
    }
</style>


@code {
    private LoginModel loginModel = new();
    private string errorMessage;
    private bool isLoading = false;

    private async Task LoginUser()
    {
        isLoading = true;
        bool success = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);
        isLoading = false;
        if (success)
        {
            Navigation.NavigateTo("/cards");
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters long.")]
        public string Password { get; set; }
    }
}